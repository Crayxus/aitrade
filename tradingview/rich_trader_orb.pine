// @version=5
// ╔══════════════════════════════════════════════════════════════════╗
// ║  RICH TRADER — ORB  (Opening Range Breakout)                    ║
// ║  Auto-generated by optimizer.py (walk-forward validated)        ║
// ║                                                                  ║
// ║  XAUUSD  London open 15:00 BJ  TP=0.5x  SL_buf=0.60x  score>=1       ║
// ║  NAS100  NY open    21:00 BJ   TP=0.5x  SL_buf=0.60x  score>=2       ║
// ║  USOIL   NY open    21:00 BJ   TP=1.0x  SL_buf=0.00x  score>=2       ║
// ║  Exit all: 03:00 BJ  (19:00 UTC)                                ║
// ╚══════════════════════════════════════════════════════════════════╝
strategy("Rich Trader — ORB", overlay=true, pyramiding=0,
     default_qty_type=strategy.cash, default_qty_value=200,
     initial_capital=10000, currency=currency.USD,
     process_orders_on_close=false)

// ── Inputs ───────────────────────────────────────────────────────
g1 = "Session"
i_session = input.string("London", "Session", options=["London","NY"], group=g1)

g2 = "ORB Parameters"
i_tp_mult = input.float(0.5, "TP × Range Size", step=0.25, minval=0.25, group=g2)
i_sl_buf  = input.float(0.6,  "SL Buffer × ATR",  step=0.1, minval=0.0,  group=g2)
i_atr_min = input.float(0.3, "Min range / ATR (skip narrow)", step=0.1, group=g2)
i_atr_max = input.float(2.0, "Max range / ATR (skip spike)",  step=0.1, group=g2)
i_sc_min  = input.int(1,   "Min |score| (0=off)", minval=0, maxval=6, group=g2)

// ── Beijing time ─────────────────────────────────────────────────
bj_h   = hour(time, "Asia/Shanghai")
bj_m   = minute(time, "Asia/Shanghai")
bj_min = bj_h * 60 + bj_m
bj_day = year(time,"Asia/Shanghai")*10000
       + month(time,"Asia/Shanghai")*100
       + dayofmonth(time,"Asia/Shanghai")

// Entry windows (minutes since midnight BJ)
// London 15:00-17:00 BJ  NY 22:00-23:00 BJ
rng_def_s = i_session=="London" ? 0    : 1260   // range definition start
rng_def_e = i_session=="London" ? 900  : 1320   // range definition end (= entry start)
entry_s   = i_session=="London" ? 900  : 1320
entry_e   = i_session=="London" ? 1020 : 1380
exit_h    = 3                                    // 03:00 BJ force exit

in_range_def = bj_min >= rng_def_s and bj_min < rng_def_e
in_entry     = bj_min >= entry_s   and bj_min < entry_e
in_exit      = bj_h   >= exit_h   and bj_h   < 9

// ── Opening range (reset each BJ calendar day) ───────────────────
var float orb_h   = na
var float orb_l   = na
var int   orb_day = 0

if bj_day != orb_day
    orb_h   := na
    orb_l   := na
    orb_day := bj_day

if in_range_def
    orb_h := na(orb_h) ? high : math.max(orb_h, high)
    orb_l := na(orb_l) ? low  : math.min(orb_l, low)

orb_rng = na(orb_h) or na(orb_l) ? na : orb_h - orb_l

// ── ATR (daily data) and 6-signal score ──────────────────────────
atr14  = ta.atr(14)
d_cls  = request.security(syminfo.tickerid, "D", close,    lookahead=barmerge.lookahead_off)
d_opn  = request.security(syminfo.tickerid, "D", open,     lookahead=barmerge.lookahead_on)
d_prv  = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_on)
h_cls  = request.security(syminfo.tickerid, "60", close,   lookahead=barmerge.lookahead_off)

ema20d = ta.ema(d_cls, 20)
ema50d = ta.ema(d_cls, 50)
mom20  = d_cls[20] != 0 ? (d_cls - d_cls[20]) / d_cls[20] : 0.0
rsi14  = ta.rsi(d_cls, 14)
gap    = d_prv  != 0 ? (d_opn - d_prv) / d_prv : 0.0
ema20h = ta.ema(h_cls, 20)

s1 = d_cls > ema20d ? 1 : -1
s2 = mom20  > 0     ? 1 : -1
s3 = gap    > 0.0005 ? 1 : gap < -0.0005 ? -1 : 0
s4 = rsi14  < 40    ? 1 : rsi14 > 60 ? -1 : 0
s5 = h_cls  > ema20h ? 1 : -1
s6 = d_cls  > ema50d ? 1 : -1
score = s1+s2+s3+s4+s5+s6

// ── Range validity ────────────────────────────────────────────────
range_ok = not na(orb_rng) and atr14 > 0
    and orb_rng >= i_atr_min * atr14
    and orb_rng <= i_atr_max * atr14

// ── Breakout detection ────────────────────────────────────────────
var int last_day = 0
no_pos = strategy.position_size == 0
fresh  = last_day != bj_day

sl_extra = i_sl_buf * atr14

long_brk  = in_entry and range_ok and close > orb_h
short_brk = in_entry and range_ok and close < orb_l

sc_ok_l = i_sc_min == 0 or score >=  i_sc_min
sc_ok_s = i_sc_min == 0 or score <= -i_sc_min

sig_long  = long_brk  and sc_ok_l and no_pos and fresh
sig_short = short_brk and sc_ok_s and no_pos and fresh

// ── Entries ───────────────────────────────────────────────────────
if sig_long
    sl_l = orb_l - sl_extra
    tp_l = close + i_tp_mult * orb_rng
    strategy.entry("L", strategy.long,
        comment="ORB LONG " + str.tostring(score) + "/6")
    strategy.exit("Lx","L", stop=sl_l, limit=tp_l, comment="TP/SL")
    last_day := bj_day

if sig_short
    sl_s = orb_h + sl_extra
    tp_s = close - i_tp_mult * orb_rng
    strategy.entry("S", strategy.short,
        comment="ORB SHORT " + str.tostring(score) + "/6")
    strategy.exit("Sx","S", stop=sl_s, limit=tp_s, comment="TP/SL")
    last_day := bj_day

// ── Force-exit 03:00 BJ ───────────────────────────────────────────
if in_exit and not no_pos
    strategy.close_all(comment="03:00 EXIT")

// ── Alerts ────────────────────────────────────────────────────────
if sig_long
    alert('{"action":"LONG","symbol":"' + syminfo.ticker
        + '","price":'  + str.tostring(math.round(close,4))
        + ',"score":'   + str.tostring(score)
        + ',"orb_h":'   + str.tostring(math.round(orb_h,4))
        + ',"orb_l":'   + str.tostring(math.round(orb_l,4)) + '}',
        alert.freq_once_per_bar_close)
if sig_short
    alert('{"action":"SHORT","symbol":"' + syminfo.ticker
        + '","price":'  + str.tostring(math.round(close,4))
        + ',"score":'   + str.tostring(score) + '}',
        alert.freq_once_per_bar_close)
if in_exit and not no_pos
    alert('{"action":"EXIT","symbol":"' + syminfo.ticker
        + '","price":'  + str.tostring(math.round(close,4)) + '}',
        alert.freq_once_per_bar_close)

// ── Visuals ───────────────────────────────────────────────────────
plot(orb_h, "ORB High", color.new(color.yellow,20), 1, plot.style_stepline)
plot(orb_l, "ORB Low",  color.new(color.yellow,20), 1, plot.style_stepline)
plot(ema20d, "EMA20(D)", color.new(color.blue,  55), 1)
plot(ema50d, "EMA50(D)", color.new(color.orange,55), 1)

plotshape(sig_long,  style=shape.triangleup,   location=location.belowbar,
    color=color.lime, size=size.normal, title="ORB Long")
plotshape(sig_short, style=shape.triangledown, location=location.abovebar,
    color=color.red,  size=size.normal, title="ORB Short")

bgcolor(in_range_def ? color.new(color.gray, 92)  : na, title="Range Def Window")
bgcolor(in_entry      ? color.new(color.green,88) : na, title="Entry Window")
bgcolor(in_exit       ? color.new(color.red,  93) : na, title="Exit Window")

// ── Info table ────────────────────────────────────────────────────
sc_c(v) => v > 0 ? color.lime : v < 0 ? color.red : color.gray
var table t = table.new(position.top_right, 2, 10,
    bgcolor=color.new(color.black,70), border_width=1,
    border_color=color.new(color.gray,70))
if barstate.islast
    table.cell(t,0,0,"RICH ORB",      text_color=color.white,  text_size=size.small)
    table.cell(t,1,0,syminfo.ticker,  text_color=color.yellow, text_size=size.small)
    sc_clr = math.abs(score)>=i_sc_min?(score>0?color.lime:color.red):color.gray
    table.cell(t,0,1,"SCORE",   text_color=color.silver, text_size=size.tiny)
    table.cell(t,1,1,str.tostring(score)+"/6", text_color=sc_clr, text_size=size.small)
    table.cell(t,0,2,"ORB HIGH", text_color=color.silver, text_size=size.tiny)
    table.cell(t,1,2,na(orb_h)?"–":str.tostring(math.round(orb_h,2)),
        text_color=color.white, text_size=size.small)
    table.cell(t,0,3,"ORB LOW",  text_color=color.silver, text_size=size.tiny)
    table.cell(t,1,3,na(orb_l)?"–":str.tostring(math.round(orb_l,2)),
        text_color=color.white, text_size=size.small)
    rng_r = na(orb_rng) or atr14==0 ? 0.0 : orb_rng/atr14
    table.cell(t,0,4,"RNG/ATR", text_color=color.silver, text_size=size.tiny)
    table.cell(t,1,4,str.tostring(math.round(rng_r,2)),
        text_color=range_ok?color.lime:color.orange, text_size=size.small)
    table.cell(t,0,5,"ATR14",   text_color=color.silver, text_size=size.tiny)
    table.cell(t,1,5,str.tostring(math.round(atr14,2)), text_color=color.white, text_size=size.small)
    table.cell(t,0,6,"EMA20",   text_color=color.silver, text_size=size.tiny)
    table.cell(t,1,6,s1>0?"BULL":"BEAR", text_color=sc_c(s1), text_size=size.small)
    table.cell(t,0,7,"RSI14",   text_color=color.silver, text_size=size.tiny)
    table.cell(t,1,7,str.tostring(math.round(rsi14,1)),
        text_color=rsi14<40?color.lime:rsi14>60?color.red:color.gray, text_size=size.small)
    s_txt = in_range_def?"RANGE DEF":in_entry?"ENTRY OK":in_exit?"03:00 EXIT":"WAITING"
    s_clr = in_range_def?color.yellow:in_entry?color.lime:in_exit?color.red:color.gray
    table.cell(t,0,8,"SESSION", text_color=color.silver, text_size=size.tiny)
    table.cell(t,1,8,s_txt,     text_color=s_clr,        text_size=size.small)
    table.cell(t,0,9,"VALID?",  text_color=color.silver, text_size=size.tiny)
    table.cell(t,1,9,range_ok?"YES":"NO",
        text_color=range_ok?color.lime:color.orange, text_size=size.small)
